<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_pml_bom_list" model="ir.ui.view">
        <field name="name">pml.bom.list</field>
        <field name="model">pml.bom</field>
        <field name="arch" type="xml">
            <list string="Bills of Materials">
                <field name="name"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="uom_id"/>
                <field name="version"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-muted="status == 'archived'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_pml_bom_form" model="ir.ui.view">
        <field name="name">pml.bom.form</field>
        <field name="model">pml.bom</field>
        <field name="arch" type="xml">
            <form string="Bill of Materials">
                <header>
                    <button name="action_archive" string="Archive"
                            type="object" class="btn-secondary"
                            invisible="status == 'archived'"/>
                    <button name="action_unarchive" string="Unarchive"
                            type="object" class="btn-secondary"
                            invisible="status == 'active'"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="active,archived"/>
                </header>
                <sheet readonly="status == 'archived'">
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_ecos" type="object"
                                class="oe_stat_button" icon="fa-cogs"
                                invisible="eco_count == 0">
                            <field name="eco_count" widget="statinfo" string="ECOs"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="BOM-000001"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="uom_id"/>
                        </group>
                        <group string="Info">
                            <field name="version"
                                   help="Numeric read-only field. Updates only when ECO of this BoM is applied."/>
                            <field name="status"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Components" name="components">
                            <field name="component_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="to_consume"/>
                                </list>
                            </field>
                        </page>
                        <page string="Operations" name="operations">
                            <field name="operation_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="work_center"/>
                                    <field name="duration"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_pml_bom" model="ir.actions.act_window">
        <field name="name">Bills of Materials</field>
        <field name="res_model">pml.bom</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Bill of Materials!
            </p>
        </field>
    </record>

</odoo>
