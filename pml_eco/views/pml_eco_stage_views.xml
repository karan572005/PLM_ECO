<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Stage List View -->
    <record id="view_pml_eco_stage_list" model="ir.ui.view">
        <field name="name">pml.eco.stage.list</field>
        <field name="model">pml.eco.stage</field>
        <field name="arch" type="xml">
            <list string="ECO Stages">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="is_first"/>
                <field name="is_done"/>
                <field name="fold"/>
            </list>
        </field>
    </record>

    <!-- Stage Form View -->
    <record id="view_pml_eco_stage_form" model="ir.ui.view">
        <field name="name">pml.eco.stage.form</field>
        <field name="model">pml.eco.stage</field>
        <field name="arch" type="xml">
            <form string="ECO Stage">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="is_first"/>
                            <field name="is_done"/>
                            <field name="fold"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Approvals" name="approvals">
                            <field name="approval_ids">
                                <list editable="bottom">
                                    <field name="user_id"/>
                                    <field name="approval_type"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_pml_eco_stage" model="ir.actions.act_window">
        <field name="name">ECO Stages</field>
        <field name="res_model">pml.eco.stage</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first ECO Stage!
            </p>
        </field>
    </record>

</odoo>
