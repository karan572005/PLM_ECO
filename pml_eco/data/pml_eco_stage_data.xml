<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Default ECO Stages created on module install -->

    <record id="pml_eco_stage_new" model="pml.eco.stage">
        <field name="name">New</field>
        <field name="sequence">10</field>
        <field name="is_first">True</field>
        <field name="is_done">False</field>
        <field name="fold">False</field>
    </record>

    <record id="pml_eco_stage_in_progress" model="pml.eco.stage">
        <field name="name">In Progress</field>
        <field name="sequence">20</field>
        <field name="is_first">False</field>
        <field name="is_done">False</field>
        <field name="fold">False</field>
    </record>

    <record id="pml_eco_stage_done" model="pml.eco.stage">
        <field name="name">Done</field>
        <field name="sequence">30</field>
        <field name="is_first">False</field>
        <field name="is_done">True</field>
        <field name="fold">False</field>
    </record>

    <!-- BoM Reference Sequence -->
    <record id="seq_pml_bom" model="ir.sequence">
        <field name="name">PML Bill of Materials</field>
        <field name="code">pml.bom</field>
        <field name="prefix">BOM/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
